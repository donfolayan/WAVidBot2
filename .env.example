# WABotII Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Docker Hub (used by docker-compose to pull the bot image)
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_REPO=your_repo_name

# Application Configuration
APP_NAME=WABotII
APP_VERSION=0.1.0
DEV_MODE=false
LOG_LEVEL=INFO
PORT=8000
BASE_URL=https://your-domain.com

# WAHA Configuration
# Local dev: http://waha:3000 (docker-compose)
# Railway: https://<waha-service>.up.railway.app
# Oracle: http://<oracle-ip>:3000
WAHA_BASE_URL=https://your-waha-service.up.railway.app
WAHA_SESSION_NAME=default
WAHA_API_KEY=your_api_key_here
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=your_password_here
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=your_password_here
WHATSAPP_DEFAULT_ENGINE=NOWEB

# WAHA Webhook Callback URL (set on the WAHA server, not the bot)
# Points WAHA back to your Railway bot instance
WAHA_CALLBACK_URL=https://your-railway-app.up.railway.app/webhook

# WhatsApp Webhook Verification Token
VERIFY_TOKEN=your_webhook_verify_token_here

# Database Configuration
DATABASE_URL=sqlite:///./wabotii.db

# Cloudinary Configuration (for cloud storage)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# File Retention Settings (in hours)
FILE_RETENTION_HOURS=1
CLOUDINARY_RETENTION_HOURS=24
MAX_FILE_SIZE_MB=16
DOWNLOAD_TIMEOUT_SECONDS=300

# Optional: Cookie Files (base64 encoded)
YOUTUBE_COOKIES_CONTENT=
FACEBOOK_COOKIES_CONTENT=
